# ---- Dart / Flutter ----
.dart_tool/
.packages
.pub-cache/
.pub/
build/
pubspec.lock          # apps may commit this; libraries should not — uncomment per project
**/doc/api/
*.dart.js
*.info.json
*.js_
*.js.deps
*.js.map
.flutter-plugins
.flutter-plugins-dependencies
.fvm/

# Generated by codegen (build_runner) — commit if you don't build in CI
# *.g.dart
# *.freezed.dart

# ---- iOS / Android build artifacts ----
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
android/.gradle/
android/local.properties
android/key.properties        # never commit signing secrets
**/*.keystore
**/*.jks
*.ipa
*.apk
*.aab

# ---- macOS / editors ----
.DS_Store
*.iml
.idea/
.vscode/
*.swp
*~
*.log

# ---- Python (skill scripts) ----
__pycache__/
*.py[cod]

# NOTE: do NOT ignore the tool-specific skill copies (.claude/, .cursor/) — committed mirrors
# produced by scripts/sync-skill.sh and .agents/agents/sync-agents.py.
